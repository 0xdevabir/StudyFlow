# ────────────────────────────────────────────────────────────────────────────
# StudyFlow environment. Copy to .env, fill what you need.
# Anything not set is mocked (email, redis). Auth secrets MUST be set.
# ────────────────────────────────────────────────────────────────────────────

# Node
NODE_ENV=development

# Database (Neon / local Postgres)
DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/studyflow?sslmode=require
DIRECT_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/studyflow?sslmode=require

# Better Auth — REQUIRED
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (optional in dev; email/password works without it)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Outbound email (Resend / SMTP). In dev, better-auth logs verification links to the console.
RESEND_API_KEY=

# Optional Redis (rate-limit + cache). If unset, in-memory fallback is used.
REDIS_URL=

# API
PORT=4000
LOG_LEVEL=debug
CORS_ORIGIN=http://localhost:3000

# Web (accessible to the browser)
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_URL=http://localhost:3000