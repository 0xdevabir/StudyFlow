{
  "name": "@studyflow/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate --config=drizzle.config.mts",
    "migrate": "drizzle-kit migrate --config=drizzle.config.mts",
    "push": "drizzle-kit push --config=drizzle.config.mts",
    "studio": "drizzle-kit studio --config=drizzle.config.mts",
    "seed": "tsx src/seed.ts",
    "reset": "drizzle-kit push --force --config=drizzle.config.mts && pnpm seed",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.9.4",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.33.0",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@studyflow/config": "workspace:*",
    "@types/node": "^22.7.5",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.24.2",
    "eslint": "^9.12.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
